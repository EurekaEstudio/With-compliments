{
	# Global options
	admin off
	auto_https off
}

:80 {
	# Set root directory
	root * /srv

	# Enable compression (gzip, zstd, brotli)
	encode gzip zstd

	# Security headers
	header {
		# XSS Protection
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		
		# Remove server info
		-Server
		-X-Powered-By

		# Cache control for HTML (no cache, always revalidate)
		@html {
			path *.html /
		}
		Cache-Control "no-cache, no-store, must-revalidate" @html

		# Cache static assets (1 year)
		@static {
			path *.js *.css *.woff *.woff2 *.ttf *.eot *.svg *.png *.jpg *.jpeg *.webp *.gif *.ico
		}
		Cache-Control "public, max-age=31536000, immutable" @static
	}

	# Try files, fallback to index.html for SPA routing
	try_files {path} /index.html

	# Serve files
	file_server

	# Logging (optional, comment out in production)
	log {
		output stdout
		format console
		level ERROR
	}
}
